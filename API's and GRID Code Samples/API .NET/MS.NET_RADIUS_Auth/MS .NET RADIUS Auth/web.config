<configuration>
 <system.web>
<authentication mode="Forms">
      <forms name=".CCRADAuth"
             loginUrl="login.aspx"
	     defaultUrl="default.aspx"
             protection="All" 
             timeout="1" 
             path="/"/> 
    </authentication>
   <authorization>
       <deny users="?"/>
   </authorization>
</system.web>
<location path="img">
    <system.web>
        <authorization>
            <allow users="*"/>
        </authorization>
    </system.web>
</location>
</configuration>
