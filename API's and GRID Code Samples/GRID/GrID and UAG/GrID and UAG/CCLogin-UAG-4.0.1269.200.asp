function isDisplayMsg
	dim retValue
	retValue = false

	if g_login_type = RESOURCE_OPERATION_LOGIN then
		'getting params only when necessary
		agent = Request.ServerVariables("HTTP_USER_AGENT")
		lowerAgent = LCase(agent)
		bIE6onXPSP2 = false
		bIE6onWin2003 = false
		bIE6onWinVista = false
		bIEonWin7 = false
		if InStr(lowerAgent,"sv1") > 0 or InStr(lowerAgent,"msie 7") > 0 or InStr(lowerAgent,"msie 8") > 0 then 'Popup blocker
			if InStr(lowerAgent,"windows nt 5.1") > 0 then 'Win XP
				bIE6onXPSP2 = true
			elseif InStr(lowerAgent,"windows nt 5.2") > 0 then 'Win 2003
				bIE6onWin2003 = true
			elseif InStr(lowerAgent,"windows nt 6.0") > 0 then 'Win Vista / Win Server 2008
				bIE6onWinVista = true
			elseif InStr(lowerAgent,"windows nt 6.1") > 0 then 'Win 7
				bIEonWin7 = true
			end if
		end if

		if bIE6onXPSP2 or bIE6onWin2003 or bIE6onWinVista or InStr(lowerAgent,"msie 7") > 0 or InStr(lowerAgent,"msie 8") > 0 then
			'UsePortalFrame is true when admin mark this option on configuration. This is the default behavior,
			'and in this case when using the portal, popup blocker does not block the div timout notifications.
			bUsePortalFrame = GetSessionParam(g_cookie,"UsePortalFrame")
			if EvaluateSessionParam(bUsePortalFrame) = false then
				'SiteIn_PopupBlocker_AllowedList is set to true by detection when user chooses to add site to popup blocker allow list
				bSiteAllowsPopups = GetSessionParam(g_cookie,"SiteIn_PopupBlocker_AllowedList")
				if EvaluateSessionParam(bSiteAllowsPopups) <> true then
					retValue = true
				end if
			end if
			if bIE6onXPSP2 then
				Components_ProblematicXPSP2 = GetSessionParam(g_cookie,"Components_ProblematicXPSP2")
				if EvaluateSessionParam(Components_ProblematicXPSP2) = true then
					retValue = true
					bShowPopupMsg = true
				end if
			end if
		end if

		'checking useragent for 64-bit browser
		bWin64 = false
		if ParameterAsBool("Win64") then
			bWin64 = true
			retValue = true
		end if
	end if
	isDisplayMsg = retValue
end function
