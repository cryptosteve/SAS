'Variables are global since they are in use later on this page
dim agent, lowerAgent, bIE6onXPSP2, bIE6onWin2003, bIE6onWinVista, bIEonWin7, Components_ProblematicXPSP2, bSiteAllowsPopups, bUsePortalFrame, bWin64, sDisabled, bShowPopupMsg

sDisabled = ""
if isPDA = true then
    sDisabled = "disabled"
