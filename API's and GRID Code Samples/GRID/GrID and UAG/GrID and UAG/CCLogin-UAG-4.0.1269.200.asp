<script language="JavaScript">
var loginDone = false;

var timeoutURL = "";
var bHandleSessionTimeout = false;

<%if g_login_type = RESOURCE_OPERATION_LOGIN_AFTER_LOGOFF then%>
	//WhlScheduledLogoff cookie is used in Web Monitor to prevent calls on scheduled logoff status
	document.cookie = "WhlScheduledLogoff=True; path=/;";
	try
	{
		window.top.document.title = "<%=loginTitle%>";
		parent.document.getElementById("portal_frameset").rows = "100%, 0px";
	}
	catch(e)
	{}

	var today = new Date();
	var expiredDate = new Date(today.getTime() + 60*60*1000);
	var expiredDateGMT = expiredDate.toGMTString();
	//set value of WhlLogoffReason
	document.cookie = "WhlLogoffReason=SCHEDULED_LOGOFF; expires=" + expiredDateGMT + ";path=/";

	bHandleSessionTimeout = true;
	timeoutURL = "<%=GetSiteLogoffPage()%>?site_name=<%=g_site_name%>&secure=<%=g_secure%>";
<%elseif g_login_type = RESOURCE_OPERATION_LOGIN then%>
	try
	{
		if (parent.parent.document.getElementById("portal_frameset"))
			parent.location.replace("<%=GetSiteLogoffPage()%>?site_name=<%=g_site_name%>&secure=<%=g_secure%>");
	}
	catch(e)
	{}

	bHandleSessionTimeout = true;
	timeoutURL = "<%=GetSiteErrorPage()%>" + "?error_code=117";
<%end if%>

//for old browsers. To support document.getElementById
if(document.all && !document.getElementById)
{
	document.getElementById = function(id)
	{
		return document.all[id];
	}
}

function SubmitForm()
{
	if (loginDone)
		return false;
	for (i = 0 ; i < document.form1.length ; i++)
	{
		var tempobj = document.form1.elements[i];
		if (tempobj.type == 'text' || tempobj.type == 'password')
		{
			if (tempobj.value.toString() == "")
			{
				alert("<%=GetString(102, "Complete all the required fields before logging on.")%>");
				SetFocus();
				return false;
			}
		}
	}
<%if rds_effective then%>
	if (!rds_sso_in_hook("<%=Server.HTMLEncode(Session("SiteInfo").PublicName)%>","<%=Server.HTMLEncode(Session("SiteInfo").CertHash)%>"))
		return false;
<%end if%>
	loginDone = true;
	return true;
}

function ResetForm()
{
	document.form1.reset();
	SetFocus();
	return false;
}

function SetFocus()
{
	if (document.form1.elements[0].value.toString() == "")
		document.form1.elements[0].focus();
	else if (document.form1.elements[1].value.toString() == "")
		document.form1.elements[1].focus();
	else
		document.form1.elements[2].focus();
}

var BlackShieldGrIDPageLocation = 'http://IP Address or hostname of BlackShield ID Server/blackshieldss/index.aspx';


function loadGrID()
{
	if (document.form1.useGrID.checked == 1) {
		otpOutter.style.display="";
		document.getElementById('otp').src = BlackShieldGrIDPageLocation + '?getChallengeImage=true&userName=' +  document.form1.user_name.value.toString();
   	} else {
		otpOutter.style.display="none";
		document.getElementById('otp').src = "";
	}
}

function selectLang()
{
	var today = new Date();
	//remove host cookie in case it exists
	var oldExpiredDate = new Date(today.getTime() - 365 * 24 * 60 * 60 * 1000); // -1 year
	var oldExpiredDateGMT = oldExpiredDate.toGMTString();
	var oldCookie = "WhlLanguage=NA; expires=" + oldExpiredDateGMT + ";path=/;";
	
	<%if g_trunk_domain_name <> GetRealDomain then%>
		//domain without AAM, or shortname/IP - remove domain cookie%>
		oldCookie = oldCookie + " domain=.<%=GetRealDomain()%>";
	<%end if%>

	document.cookie = oldCookie;
	//set new cookie
	var expiredDate = new Date(today.getTime() + 365 * 24 * 60 * 60 * 1000); // +1 year
	var expiredDateGMT = expiredDate.toGMTString();
	document.cookie = "WhlLanguage=" + document.form1.language.value + "; expires=" + expiredDateGMT + ";path=/;<%=GetCookieDomainAttr()%>";	

    	// We need to reload the login page here, but only if the user hasn't already entered a username and/or password.
    	var confirmChangeLang = true;
    	for (i = 0 ; i < document.form1.length ; i++)
	{
		var tempobj=document.form1.elements[i];
		if (tempobj.type=='text' || tempobj.type=='password')
		{
			if (tempobj.value.toString() != "")
			{
				confirmChangeLang = confirm("<%=GetString(113, "Do you want to reload the page in the selected language?\nAll data entered on the page will be deleted.")%>");
				break;
			}
		}
	}
    	if (confirmChangeLang)
		self.location.replace("/InternalSite/RedirectToOrigURL.asp?abandon=0&site_name=<%=g_site_name%>&secure=<%=g_secure%>");
}

function window_onload()
{
        <%if rds_effective then%>
        rds_sso_init();
        <%end if%>
	if(document.body)
		document.body.style.overflow = "";
	SetFocus();
	<%if g_login_type = RESOURCE_OPERATION_LOGIN or g_login_type = RESOURCE_OPERATION_LOGIN_AFTER_LOGOFF then%>
	getWhlCookie();
	<%end if%>
	<%if isRSASoftToken = true then%>
	createRSASoftTokenLinks();
	<%end if%>
}

function keyDetect(e)
{
	if(!e)
		e = window.event;
	if(!e)
	{
		return;
	}
	var theKey = e.which ? e.which : (e.keyCode ? e.keyCode : (e.charCode ? e.charCode : 0));
	var agt = navigator.userAgent.toLowerCase();
	if (theKey == 13 || theKey == 3)
	{
		if(SubmitForm())
			document.form1.submit();
	}
}

var capsLockNote = "<%=GetString(111, "Note: The Caps Lock key is on. Passwords are case-sensitive.")%>";
</script>
